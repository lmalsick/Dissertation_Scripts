%%DocumentFonts: Helvetica
%%Pages: 1
%%EndComments

%Options:
%
%This file contains the square roots of the base pair probabilities in the form
% i  j  sqrt(p(i,j)) ubox

%%BeginProlog
/DPdict 100 dict def
DPdict begin
/logscale false def
/lpmin 1e-05 log def

/box { %size x y box - draws box centered on x,y
   2 index 0.5 mul sub            % x -= 0.5
   exch 2 index 0.5 mul sub exch  % y -= 0.5
   3 -1 roll dup rectfill
} bind def

/ubox {
   logscale {
      log dup add lpmin div 1 exch sub dup 0 lt { pop 0 } if
   } if
   3 1 roll
   exch len exch sub 1 add box
} bind def

/lbox {
   3 1 roll
   len exch sub 1 add box
} bind def

/drawseq {
% print sequence along all 4 sides
[ [0.7 -0.3 0 ]
  [0.7 0.7 len add 0]
  [-0.3 len sub -0.4 -90]
  [-0.3 len sub 0.7 len add -90]
] {
   gsave
    aload pop rotate translate
    0 1 len 1 sub {
     dup 0 moveto
     sequence exch 1 getinterval
     show
    } for
   grestore
  } forall
} bind def

/drawgrid{
  0.01 setlinewidth
  len log 0.9 sub cvi 10 exch exp  % grid spacing
  dup 1 gt {
     dup dup 20 div dup 2 array astore exch 40 div setdash
  } { [0.3 0.7] 0.1 setdash } ifelse
  0 exch len {
     dup dup
     0 moveto
     len lineto
     dup
     len exch sub 0 exch moveto
     len exch len exch sub lineto
     stroke
  } for
  [] 0 setdash
  0.04 setlinewidth
  currentdict /cutpoint known {
    cutpoint 1 sub
    dup dup -1 moveto len 1 add lineto
    len exch sub dup
    -1 exch moveto len 1 add exch lineto
    stroke
  } if
  0.5 neg dup translate
} bind def

end
%%EndProlog
DPdict begin
%delete next line to get rid of title
270 665 moveto /Helvetica findfont 14 scalefont setfont (dot.ps) show

/sequence { (\
AAGC----------AAUA-U------------------A---AG-AAAAUUU-UGG-A----UAC-----AA-C-AGUGUC-AG--------GCCAAA-UUGAG-A---A---GUC----UUG-CCACAGCU---U-GG--GA----------G----AC---G--------G-U-----GCAGCC----UG---CA----------------------------AAAGCU----------------------------C---U--GG----A---AGGAGAAUG---GACUCCCUGC------G-C---AA-------------UG-CAGACCAGA-------------AUGUGCCACUGGAA--------GGUCAGU-GCAGG-CAGC-A--G-CGAAC--UCUCGGUUGA-----GAGG-ACCGGGUU---------------------------------ACCGU---------------G-AC-AU---CCC-ACC-UAGA----GAAAG---UAGA-----AC-GGAGCCUCCGCC------AGUG---AGGCUU--CAUGUG---GUU-----GUG---GUAAG--AUG---GGGUCUAGAGGUUAGAGGA--------GACCCUCUACUAA--GC-A--GAUUUU-GCAA----UAUAUU-GACACCAGG--GAAAGACCGG--GUGGUUCUCUGUUCCU---GAGCUCCGGAGGCCA--GGGCACAGUUUGCCCGACA---AUA-ACUGGCCUUU-GGG--UCGGAGAAACACC-AACCACU\
) } def
/len { sequence length } bind def

72 216 translate
72 6 mul len 1 add div dup scale
/Helvetica findfont 0.95 scalefont setfont

drawseq
0.5 dup translate
% draw diagonal
0.04 setlinewidth
0 len moveto len 0 lineto stroke

drawgrid

